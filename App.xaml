<Application x:Class="ModernAssetTool.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="SimpleMainWindow.xaml">
    <Application.Resources>
        <Color x:Key="PageTopColor">#FFF8EF</Color>
        <Color x:Key="PageBottomColor">#FFF8EF</Color>
        <Color x:Key="CardColor">#FAFCFF</Color>
        <Color x:Key="InkColor">#2D2D2D</Color>
        <Color x:Key="MutedInkColor">#63666A</Color>
        <Color x:Key="AccentColor">#951829</Color>
        <Color x:Key="AccentDarkColor">#641A2B</Color>
        <Color x:Key="HeroColor">#641A2B</Color>

        <SolidColorBrush x:Key="PageTopBrush" Color="{StaticResource PageTopColor}" />
        <SolidColorBrush x:Key="PageBottomBrush" Color="{StaticResource PageBottomColor}" />
        <SolidColorBrush x:Key="CardBrush" Color="{StaticResource CardColor}" />
        <SolidColorBrush x:Key="InkBrush" Color="{StaticResource InkColor}" />
        <SolidColorBrush x:Key="MutedInkBrush" Color="{StaticResource MutedInkColor}" />
        <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
        <SolidColorBrush x:Key="AccentDarkBrush" Color="{StaticResource AccentDarkColor}" />
        <SolidColorBrush x:Key="HeroBrush" Color="{StaticResource HeroColor}" />

        <LinearGradientBrush x:Key="PageBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="{StaticResource PageTopColor}" Offset="0" />
            <GradientStop Color="#F2D4D7" Offset="0.52" />
            <GradientStop Color="{StaticResource PageBottomColor}" Offset="1" />
        </LinearGradientBrush>

        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBrush}" />
            <Setter Property="BorderBrush" Value="#DCE4EC" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="24" />
            <Setter Property="Padding" Value="22" />
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI Variable Text" />
            <Setter Property="FontSize" Value="26" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
        </Style>

        <Style x:Key="BodyTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI Variable Text" />
            <Setter Property="Foreground" Value="{StaticResource MutedInkBrush}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI Variable Text" />
            <Setter Property="Foreground" Value="#476072" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <Style x:Key="ModernTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="42" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="BorderBrush" Value="#C6D4DF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#F8FBFD" />
            <Setter Property="FontFamily" Value="Segoe UI Variable Text" />
            <Setter Property="FontSize" Value="15" />
        </Style>

        <Style x:Key="GhostButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="18,10" />
            <Setter Property="Background" Value="White" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="BorderBrush" Value="#D3DCE4" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontFamily" Value="Segoe UI Variable Text" />
            <Setter Property="FontSize" Value="14" />
        </Style>

        <Style x:Key="AccentButtonStyle" TargetType="Button" BasedOn="{StaticResource GhostButtonStyle}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
        </Style>
    </Application.Resources>
</Application>
