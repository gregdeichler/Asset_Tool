<Window x:Class="ModernAssetTool.App.SimpleMainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Asset Tool"
        Icon="Assets/AssetTool.ico"
        Width="980"
        Height="660"
        MinWidth="980"
        MinHeight="660"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource PageBackgroundBrush}"
        FontFamily="Segoe UI Variable Text">
    <Viewbox Stretch="Uniform">
    <Grid Width="1220" Height="820" Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="18"
                CornerRadius="26"
                Background="{StaticResource HeroBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Asset Tool"
                               FontSize="28"
                               FontWeight="SemiBold"
                               Foreground="White" />
                    <TextBlock Margin="0,8,0,0"
                               Text="Vassar College CIS workstation assignment and asset update utility."
                               FontSize="13"
                               Foreground="#F2D9DF" />
                </StackPanel>

                <Border Grid.Column="1"
                        Padding="12,9"
                        Background="#1EFFFFFF"
                        CornerRadius="18">
                    <StackPanel>
                        <TextBlock Text="Session"
                                   Foreground="White"
                                   FontSize="12"
                                   FontWeight="SemiBold" />
                        <TextBlock x:Name="AdminStateText"
                                   Margin="0,6,0,0"
                                   Foreground="#F2D9DF"
                                   FontSize="12" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.08*" />
                <ColumnDefinition Width="0.92*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Margin="0,0,16,0"
                    Padding="20"
                    Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.ColumnSpan="2"
                               Text="Assignment"
                               Style="{StaticResource SectionTitleStyle}"
                               FontSize="22" />
                    <TextBlock Grid.Row="1"
                               Grid.ColumnSpan="2"
                               Margin="0,6,0,0"
                               Text="Enter the two pieces of information CIS needs for this machine."
                               Style="{StaticResource BodyTextStyle}" />

                    <StackPanel Grid.Row="2" Margin="0,16,12,0">
                        <TextBlock Text="Primary user" Style="{StaticResource FieldLabelStyle}" />
                        <TextBox x:Name="UsernameTextBox" Style="{StaticResource ModernTextBoxStyle}" />
                    </StackPanel>

                    <StackPanel Grid.Row="2" Grid.Column="1" Margin="12,16,0,0">
                        <TextBlock Text="Asset tag" Style="{StaticResource FieldLabelStyle}" />
                        <TextBox x:Name="AssetTagTextBox" Style="{StaticResource ModernTextBoxStyle}" />
                    </StackPanel>

                    <Border Grid.Row="3"
                            Grid.ColumnSpan="2"
                            Margin="0,14,0,0"
                            Padding="12"
                            Background="#F7FAFC"
                            BorderBrush="#D6E1EA"
                            BorderThickness="1"
                            CornerRadius="18">
                        <DockPanel>
                            <CheckBox x:Name="AddLocalAdminCheckBox"
                                      Margin="0,2,14,0"
                                      VerticalAlignment="Top" />
                            <StackPanel>
                                <TextBlock Text="Grant local administrator access"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource InkBrush}" />
                                <TextBlock Text="Adds the entered user to the local Administrators group."
                                           Margin="0,3,0,0"
                                           Style="{StaticResource BodyTextStyle}"
                                           FontSize="12" />
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <Border Grid.Row="4"
                            Grid.ColumnSpan="2"
                            Margin="0,14,0,0"
                            Padding="12"
                            Background="#F7FAFC"
                            BorderBrush="#D6E1EA"
                            BorderThickness="1"
                            CornerRadius="18">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <DockPanel>
                                <CheckBox x:Name="RenameComputerCheckBox"
                                          Margin="0,2,14,0"
                                          VerticalAlignment="Top" />
                                <StackPanel>
                                    <TextBlock Text="Rename computer"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource InkBrush}" />
                                    <TextBlock Text="Optional. Letters, numbers, and hyphens only. Maximum 15 characters."
                                               Margin="0,3,0,0"
                                               Style="{StaticResource BodyTextStyle}"
                                               FontSize="12" />
                                </StackPanel>
                            </DockPanel>

                            <StackPanel Grid.Row="1" Margin="34,10,0,0">
                                <TextBlock Text="New computer name" Style="{StaticResource FieldLabelStyle}" />
                                <TextBox x:Name="NewComputerNameTextBox"
                                         IsEnabled="{Binding ElementName=RenameComputerCheckBox, Path=IsChecked}"
                                         MaxLength="15"
                                         Style="{StaticResource ModernTextBoxStyle}" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Row="5"
                            Grid.ColumnSpan="2"
                            Margin="0,14,0,0"
                            Padding="12"
                            Background="#F2F7FB"
                            BorderBrush="#D1DCE6"
                            BorderThickness="1"
                            CornerRadius="18">
                        <StackPanel>
                            <TextBlock Text="Status"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource InkBrush}" />
                            <TextBlock x:Name="StatusText"
                                       Margin="0,8,0,0"
                                       Style="{StaticResource BodyTextStyle}" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="1"
                    Margin="16,0,0,0"
                    Padding="20"
                    Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="Computer"
                               Style="{StaticResource SectionTitleStyle}"
                               FontSize="22" />

                    <Border Grid.Row="1"
                            Margin="0,14,0,0"
                            Padding="14"
                            Background="#F7F1F2"
                            BorderBrush="#E3C7CD"
                            BorderThickness="1"
                            CornerRadius="20">
                        <StackPanel>
                            <TextBlock Text="Detected machine"
                                       Foreground="{StaticResource AccentBrush}"
                                       FontSize="12"
                                       FontWeight="SemiBold" />
                            <TextBlock x:Name="ComputerText"
                                       Margin="0,8,0,0"
                                       Foreground="{StaticResource InkBrush}"
                                       FontSize="22"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap" />
                            <TextBlock Margin="0,8,0,0"
                                       Foreground="{StaticResource MutedInkBrush}"
                                       FontSize="13"
                                       TextWrapping="Wrap">
                                <Run x:Name="ManufacturerText" />
                                <Run Text=" - " />
                                <Run x:Name="ModelText" />
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <UniformGrid Grid.Row="2"
                                 Margin="0,14,0,0"
                                 Columns="2"
                                 Rows="2">
                        <Border Margin="0,0,8,8"
                                Padding="11"
                                Background="#F4F8FB"
                                BorderBrush="#DCE4EC"
                                BorderThickness="1"
                                CornerRadius="18">
                            <StackPanel>
                                <TextBlock Text="Operating system"
                                           Foreground="{StaticResource MutedInkBrush}"
                                           FontSize="12"
                                           FontWeight="SemiBold" />
                                <TextBlock x:Name="OSText"
                                           Margin="0,6,0,0"
                                           Foreground="{StaticResource InkBrush}"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Border Margin="8,0,0,8"
                                Padding="11"
                                Background="#F4F8FB"
                                BorderBrush="#DCE4EC"
                                BorderThickness="1"
                                CornerRadius="18">
                            <StackPanel>
                                <TextBlock Text="Serial"
                                           Foreground="{StaticResource MutedInkBrush}"
                                           FontSize="12"
                                           FontWeight="SemiBold" />
                                <TextBlock x:Name="SerialText"
                                           Margin="0,6,0,0"
                                           Foreground="{StaticResource InkBrush}"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Border Margin="0,8,8,0"
                                Padding="11"
                                Background="#F4F8FB"
                                BorderBrush="#DCE4EC"
                                BorderThickness="1"
                                CornerRadius="18">
                            <StackPanel>
                                <TextBlock Text="Form factor"
                                           Foreground="{StaticResource MutedInkBrush}"
                                           FontSize="12"
                                           FontWeight="SemiBold" />
                                <TextBlock x:Name="FormFactorText"
                                           Margin="0,6,0,0"
                                           Foreground="{StaticResource InkBrush}"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Border Margin="8,8,0,0"
                                Padding="11"
                                Background="#F4F8FB"
                                BorderBrush="#DCE4EC"
                                BorderThickness="1"
                                CornerRadius="18">
                            <StackPanel>
                                <TextBlock Text="Memory"
                                           Foreground="{StaticResource MutedInkBrush}"
                                           FontSize="12"
                                           FontWeight="SemiBold" />
                                <TextBlock x:Name="MemoryText"
                                           Margin="0,6,0,0"
                                           Foreground="{StaticResource InkBrush}"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <Border Grid.Row="3"
                            Margin="0,14,0,0"
                            Padding="11"
                            Background="#FCFEFF"
                            BorderBrush="#DCE4EC"
                            BorderThickness="1"
                            CornerRadius="18">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="78" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Text="UUID"
                                       Foreground="{StaticResource MutedInkBrush}"
                                       FontSize="12"
                                       FontWeight="SemiBold" />
                            <TextBlock x:Name="UuidText"
                                       Grid.Column="1"
                                       Foreground="{StaticResource InkBrush}"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap" />

                            <TextBlock Grid.Row="1"
                                       Margin="0,12,0,0"
                                       Text="Model"
                                       Foreground="{StaticResource MutedInkBrush}"
                                       FontSize="12"
                                       FontWeight="SemiBold" />
                            <TextBlock Grid.Row="1"
                                       Grid.Column="1"
                                       Margin="0,12,0,0"
                                       Foreground="{StaticResource InkBrush}"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap">
                                <Run x:Name="ManufacturerSummaryText" />
                                <Run Text=" - " />
                                <Run x:Name="ModelSummaryText" />
                            </TextBlock>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Row="2" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Margin="0,0,12,0"
                    Click="RefreshButton_OnClick"
                    Style="{StaticResource GhostButtonStyle}"
                    Content="Refresh inventory" />

            <Button Grid.Column="1"
                    Margin="0,0,12,0"
                    Click="PreferencesButton_OnClick"
                    Style="{StaticResource GhostButtonStyle}"
                    Content="Preferences" />

            <Button Grid.Column="2"
                    Click="SubmitButton_OnClick"
                    Style="{StaticResource AccentButtonStyle}"
                    Content="Submit asset info" />
        </Grid>
    </Grid>
    </Viewbox>
</Window>
