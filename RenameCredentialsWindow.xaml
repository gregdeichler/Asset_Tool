<Window x:Class="ModernAssetTool.App.RenameCredentialsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Asset Tool Rename Credentials"
        Icon="Assets/AssetTool.ico"
        Width="500"
        Height="430"
        MinWidth="500"
        MinHeight="430"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#F7FAFD"
        FontFamily="Segoe UI Variable Text">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="Domain credentials required"
                   Style="{StaticResource SectionTitleStyle}"
                   FontSize="22" />

        <TextBlock Grid.Row="1"
                   Margin="0,8,0,0"
                   Style="{StaticResource BodyTextStyle}"
                   TextWrapping="Wrap">
            <Run Text="This computer appears to be joined to " />
            <Run x:Name="DomainText" FontWeight="SemiBold" />
            <Run Text=". Enter credentials that can rename the computer in the domain. These credentials are only used for this rename and are not saved." />
        </TextBlock>

        <TextBlock Grid.Row="2"
                   Margin="0,16,0,8"
                   Text="Username"
                   Style="{StaticResource FieldLabelStyle}" />
        <TextBlock Grid.Row="2"
                   Margin="94,16,0,8"
                   Text="Use username@ad.vassar.edu or AD\username"
                   Style="{StaticResource BodyTextStyle}"
                   FontSize="12"
                   VerticalAlignment="Center" />
        <TextBox x:Name="UsernameTextBox"
                 Grid.Row="3"
                 Style="{StaticResource ModernTextBoxStyle}" />

        <TextBlock Grid.Row="4"
                   Margin="0,14,0,8"
                   Text="Password"
                   Style="{StaticResource FieldLabelStyle}" />
        <PasswordBox x:Name="PasswordTextBox"
                     Grid.Row="5"
                     Height="42"
                     Padding="12,8"
                     BorderBrush="#C6D4DF"
                     BorderThickness="1"
                     Background="#F8FBFD"
                     FontFamily="Segoe UI Variable Text"
                     FontSize="15" />

        <Grid Grid.Row="6" Margin="0,24,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="StatusText"
                       VerticalAlignment="Center"
                       Foreground="{StaticResource MutedInkBrush}" />

            <Button Grid.Column="1"
                    Margin="0,0,12,0"
                    Click="CancelButton_OnClick"
                    Style="{StaticResource GhostButtonStyle}"
                    Content="Skip rename" />

            <Button Grid.Column="2"
                    Click="ContinueButton_OnClick"
                    Style="{StaticResource AccentButtonStyle}"
                    Content="Continue" />
        </Grid>
    </Grid>
</Window>
